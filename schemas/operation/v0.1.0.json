{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:envmason:schema:operation:0.1.0",
  "title": "EnvMason Operation Record 0.1.0",
  "description": "A redacted local audit record for one confirmed EnvMason Plan execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "plan_id",
    "plan_schema_version",
    "state",
    "created_at",
    "updated_at",
    "confirmation",
    "steps",
    "transitions"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "id": { "type": "string", "pattern": "^op-[a-f0-9]{32}$" },
    "plan_id": { "$ref": "#/$defs/digest" },
    "plan_schema_version": { "type": "string", "minLength": 1 },
    "state": { "$ref": "#/$defs/state" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "confirmation": { "$ref": "#/$defs/confirmation" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/transition" }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "state": {
      "enum": ["pending", "running", "verifying", "completed", "failed", "timed_out", "cancelled", "interrupted"]
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "confirmed_plan_id", "confirmed_at"],
      "properties": {
        "scope": { "const": "plan" },
        "confirmed_plan_id": { "$ref": "#/$defs/digest" },
        "confirmed_at": { "type": "string", "format": "date-time" }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id", "tool_id", "operation", "adapter", "risk", "state",
        "precondition", "verification", "stdout", "stderr"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "tool_id": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string", "minLength": 1 },
        "risk": { "enum": ["R1", "R2", "R3", "R4"] },
        "state": { "$ref": "#/$defs/state" },
        "started_at": { "type": "string", "format": "date-time" },
        "finished_at": { "type": "string", "format": "date-time" },
        "invocation": { "$ref": "#/$defs/invocation" },
        "exit_code": { "type": "integer" },
        "error": { "$ref": "#/$defs/error" },
        "precondition": { "$ref": "#/$defs/check_result" },
        "verification": { "$ref": "#/$defs/check_result" },
        "stdout": { "$ref": "#/$defs/output" },
        "stderr": { "$ref": "#/$defs/output" }
      }
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executable", "args"],
      "properties": {
        "executable": { "type": "string", "minLength": 1 },
        "args": { "type": "array", "items": { "type": "string" } }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "check_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "enum": ["pending", "passed", "failed", "not_run"] },
        "message": { "type": "string" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "truncated"],
      "properties": {
        "text": { "type": "string" },
        "truncated": { "type": "boolean" }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "at", "reason"],
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "at": { "type": "string", "format": "date-time" },
        "action_id": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
